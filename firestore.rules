rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Machine Records
    match /machines/{machineId} {
      allow read: if request.auth != null || true;
      allow write: if request.auth.token.admin == true;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerEmail || 
        request.auth.token.admin == true
      );
    }

    // Passport Subcollections
    match /machines/{machineId}/passport/{document=**} {
      allow read: if request.auth != null || true;
      allow write: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null && request.auth.token.admin == true;
      allow update: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.uid == get(/databases/$(database)/documents/machines/$(machineId)).data.createdBy
      );
    }

    // QR Registry (Phase 2.5 prep)
    match /passport_qr_registry/{qrId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
      allow update: if request.auth != null && request.auth.token.admin == true;
    }

    // Valuation Schema (Phase 3 prep)
    match /passport_valuation_schema/{machineId} {
      allow read: if request.auth != null || true;
      allow write: if request.auth.token.admin == true;
      allow create: if request.auth != null && request.auth.token.admin == true;
    }

    // Marketplace Listings (Phase 3 prep)
    match /marketplace_listings/{listingId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.sellerId || 
        request.auth.token.admin == true
      );
      allow create: if request.auth != null && request.auth.token.admin == true;
    }

    // Counter Document
    match /_counters/{document=**} {
      allow read: if request.auth.token.admin == true;
      allow write: if request.auth.token.admin == true || request.service == 'cloud-functions';
    }
  }
}
